# Axona Bridge configuration.
# Copy to .env for local dev or /etc/axona-bridge.env for systemd.

# TCP port to listen on (default 8080).
PORT=8080

# Bind address (default 0.0.0.0). Behind nginx on the SAME host (the systemd
# path), set HOST=127.0.0.1 so the raw bridge port is NOT world-reachable —
# every request must arrive through nginx (TLS, logging, X-Forwarded-For, rate
# limits). Leave 0.0.0.0 for the Docker path (Caddy reaches it over the compose
# network).
HOST=127.0.0.1

# 'info' | 'debug' — debug logs every ping/pong (verbose).
LOG_LEVEL=info

# Operator token. Unauthenticated /healthz returns liveness only (status +
# version); the full topology body and the /diag endpoint require this token in
# an `X-Healthz-Token` header. Unset → full body/diag unavailable (closed). This
# keeps the public surface from leaking topology, the seed tell, or per-peer
# IP/node-id. Generate with: openssl rand -hex 16
# HEALTHZ_TOKEN=<random>

# ── Bridge directory (discovery + failover) ──────────────────────────
# This bridge advertises itself on the public bridge-directory topic so
# clients can discover it and fail over to it. BRIDGE_PUBLIC_URL is this
# bridge's own wss:// endpoint (required to publish).
BRIDGE_PUBLIC_URL=wss://bridge.axona.net

# 'on' (default) | 'off'. The TESTNET bridge MUST set this to 'off' — it
# runs an independent fleet and must not advertise into the public
# directory the production apps consume. ('off' also disables the uplink.)
BRIDGE_DIRECTORY=on

# Federation: on launch the bridge bootstraps INTO the live mesh as a node by
# uplinking to a known bridge, so it joins one shared connectome and its
# directory entry is visible network-wide. Optional comma-separated seed list
# of upstream bridges to try (ranked, first reachable wins); falls back to the
# persisted discovered list + built-in defaults. Self is always excluded, so a
# bridge with nothing else reachable simply runs as the seed (uplink-less).
# BRIDGE_UPSTREAMS=wss://bridge.axona.net,wss://bridge-west.axona.net

# Bridge location (advertised in the directory + used for its node id).
# BRIDGE_LAT=38.0
# BRIDGE_LNG=-77.0
# BRIDGE_REGION_LABEL=us-east
