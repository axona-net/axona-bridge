# Docker Compose env — copy to .env (docker compose auto-loads it):
#   cp .env.docker.example .env
#
# One value feeds several services, so keep them consistent:
#   DOMAIN            → Caddy TLS hostname + coturn realm + bridge BRIDGE_PUBLIC_URL
#   TURN_AUTH_SECRET  → MUST match between coturn and the bridge (it mints creds)

# ── shared / infra ───────────────────────────────────────────────────
DOMAIN=bridge.example.org
PUBLIC_IP=203.0.113.10
TURN_AUTH_SECRET=CHANGE_ME            # openssl rand -hex 32

# ── bridge runtime (passed into the bridge container via env_file) ────
PORT=8080
LOG_LEVEL=info
BRIDGE_PUBLIC_URL=wss://bridge.example.org
BRIDGE_DIRECTORY=on                   # advertise + federate (set 'off' to stay private)
BRIDGE_LAT=38.0
BRIDGE_LNG=-77.0
BRIDGE_REGION_LABEL=self
TURN_URLS=turn:bridge.example.org:3478
